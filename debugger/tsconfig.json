{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es6",
        "lib": ["es6"],
        "rootDir": "src",
        "outDir": "out",
        "sourceMap": true,
        "noUnusedLocals": true,
        "noImplicitThis": true,
        "noImplicitAny": true,
        "noImplicitReturns": true,
        "noUnusedParameters": true,
        "strictNullChecks": true,
        "alwaysStrict": true
    },
    "include": [
		"src"
	],
    "exclude": [
        "node_modules",
        ".vscode-test"
    ]
}
