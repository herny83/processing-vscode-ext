{
    "compilerOptions": {
        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "es6",
        "lib": ["es6"],
        "noEmit": true,
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true
    },
    "include": [
		"src"
	],
    "exclude": [
        "node_modules",
        ".vscode-test"
    ]
}
