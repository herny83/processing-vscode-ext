{
    "compilerOptions": {
        "target": "es6",
        "module": "esnext",
        "moduleResolution": "bundler",
        "sourceMap": true,
        "outDir": "out",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noEmit": true
    },
    "include": ["src", "client/src", "debugger/src"],
    "exclude": ["node_modules", "out"]
}
