{
  "name": "processing",
  "displayName": "Processing Language & Debugger",
  "description": "Unified VS Code extension for Processing language support and debugging.",
  "version": "0.0.1",
  "publisher": "herny83",
  "engines": {
    "vscode": ">=1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "breakpoints": [
      {
        "language": "processing"
      }
    ],
    "javaExtensions": [
      "./debugger/server/com.microsoft.java.debug.plugin-0.53.2.jar"
    ],
    "languages": [
      {
        "id": "processing",
        "aliases": [
          "Processing",
          "processing"
        ],
        "extensions": [
          ".pde"
        ],
        "configuration": "./assets/language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "processing",
        "scopeName": "source.pde",
        "path": "./assets/syntax/pde.tmLanguage.json"
      }
    ],
    "debuggers": [
      {
        "type": "processing",
        "label": "Processing Debugger",
        "program": "./debugger/out/adapter.js",
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the Processing sketch file to debug."
              }
            }
          }
        },
        "languages": [
          "processing"
        ]
      }
    ],
    "commands": [
      {
        "command": "processing.debug.runPdeFile",
        "title": "Run Processing Sketch",
        "category": "Processing"
      },
      {
        "command": "processing.debug.debugPdeFile",
        "title": "Debug Processing Sketch",
        "category": "Processing"
      },
      {
        "command": "processing.debug.runCodeLens",
        "title": "Run (CodeLens)",
        "category": "Processing"
      },
      {
        "command": "processing.debug.debugCodeLens",
        "title": "Debug (CodeLens)",
        "category": "Processing"
      },
      {
        "command": "processing.debug.runHover",
        "title": "Run (Hover)",
        "category": "Processing"
      },
      {
        "command": "processing.reloadSketch",
        "title": "Reload Sketch",
        "category": "Processing"
      },
      {
        "command": "processing.exportSketch",
        "title": "Export Sketch",
        "category": "Processing"
      },
      {
        "command": "java.debug.continueAll",
        "title": "Continue All Threads",
        "category": "Processing Debug"
      },
      {
        "command": "java.debug.continueOthers",
        "title": "Continue Other Threads",
        "category": "Processing Debug"
      },
      {
        "command": "java.debug.pauseAll",
        "title": "Pause All Threads",
        "category": "Processing Debug"
      },
      {
        "command": "java.debug.pauseOthers",
        "title": "Pause Other Threads",
        "category": "Processing Debug"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "processing.debug.runPdeFile",
          "when": "resourceExtname == .pde",
          "group": "processing@1"
        },
        {
          "command": "processing.debug.debugPdeFile",
          "when": "resourceExtname == .pde",
          "group": "processing@2"
        },
        {
          "command": "processing.exportSketch",
          "when": "resourceExtname == .pde",
          "group": "processing@3"
        }
      ],
      "explorer/context": [
        {
          "command": "processing.debug.runPdeFile",
          "when": "resourceExtname == .pde",
          "group": "processing@1"
        },
        {
          "command": "processing.debug.debugPdeFile",
          "when": "resourceExtname == .pde",
          "group": "processing@2"
        },
        {
          "command": "processing.exportSketch",
          "when": "resourceExtname == .pde",
          "group": "processing@3"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Processing",
      "properties": {
        "processing.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the Processing installation. **(Windows/Linux only — on macOS, Processing is detected automatically from `/Applications/`.)**"
        },
        "processing.launcher": {
          "type": "string",
          "default": "",
          "description": "Custom launcher for Processing sketches."
        },
        "processing.debug.settings.hotCodeReplace": {
          "type": "string",
          "enum": [
            "manual",
            "auto"
          ],
          "default": "manual",
          "description": "Hot code replacement mode during debugging."
        },
        "processing.outputPath": {
          "type": "string",
          "default": "./out/",
          "description": "Output path for exported Processing sketches (relative to sketch folder)."
        },
        "processing.debug.settings.enableRunDebugCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Enable Run/Debug CodeLens above setup() and draw() functions."
        },
        "processing.debug.vmArgs": {
          "type": "string",
          "default": "",
          "description": "Default VM arguments for Processing debug sessions."
        },
        "processing.debug.console": {
          "type": "string",
          "enum": [
            "integratedTerminal",
            "internalConsole",
            "externalTerminal"
          ],
          "default": "integratedTerminal",
          "description": "Console to use for Processing debug output."
        },
        "processing.debug.enableLibrarySourceLookup": {
          "type": "boolean",
          "default": true,
          "description": "Automatically add workspace source roots to debug source lookup paths."
        },
        "processing.debug.additionalSourcePaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional source paths for stepping into library code during debugging."
        },
        "processing.silentNotification": {
          "type": "boolean",
          "default": false,
          "description": "Show progress in status bar instead of notification popups."
        }
      }
    },
    "snippets": [
      {
        "language": "processing",
        "path": "./assets/snippets.json"
      }
    ],
    "iconThemes": [
      {
        "id": "processing-icons",
        "label": "Processing Icon Theme",
        "path": "./assets/fileicons/processing-icon-theme.json"
      }
    ]
  },
  "activationEvents": [
    "onLanguage:processing",
    "onDebug"
  ],
  "scripts": {
    "build": "npm run build -w client && npm run build -w server && npm run build -w debugger && npm run build -w shared && tsc -p .",
    "test": "npm run test -w client && npm run test -w server && npm run test -w debugger && npm run test -w shared",
    "compile": "npm run build -w client && npm run build -w server && npm run build -w debugger && npm run build -w shared && tsc -p ."
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "antlr4ts-cli": "^0.5.0-alpha.4",
    "typescript": "^5.9.3",
    "vscode-languageclient": "^9.0.1"
  },
  "workspaces": [
    "client",
    "server",
    "debugger",
    "shared"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/herny83/processing-vscode-ext.git"
  },
  "dependencies": {},
  "vsce": {
    "exclude": [
      "node_modules/**"
    ]
  }
}
